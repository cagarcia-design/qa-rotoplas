{
  "name": "rotoplas-qa-b2c-smoke",
  "version": "1.0.0",
  "description": "Suite de pruebas de humo post-deploy para qarotoplasmx.io (B2C Rotoplas)",
  "private": true,
  "scripts": {
    "postinstall": "playwright install chromium",
    "dashboard": "node scripts/dashboard.js",
    "check:b2c": "npx playwright test --project=b2c-contracts --grep-invert \"@capa2|@smoke\"",
    "check:b2c:health": "npx playwright test --project=b2c-contracts --grep @health",
    "check:b2c:contracts": "npx playwright test --project=b2c-contracts --grep @contract",
    "check:b2c:content": "npx playwright test --project=b2c-contracts --grep @content",
    "check:b2c:anon": "npx playwright test --project=b2c-contracts --grep-invert \"@auth|@capa2|@smoke\"",
    "check:b2c:forms:email": "npx playwright test --project=b2c-contracts --grep @email",
    "check:b2c:purchase": "npx playwright test --project=b2c-contracts --grep @purchase",
    "check:b2c:login": "npx playwright test --project=b2c-contracts --grep @login",
    "check:b2c:capa2": "npx playwright test --project=b2c-contracts --grep @capa2",
    "check:b2c:capa2:auto": "node scripts/capa2-run.js",
    "report": "npx playwright show-report",
    "auth:b2c": "node setup-auth-b2c.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "imapflow": "^1.4.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
